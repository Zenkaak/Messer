{
  "installCommand": "cd messer-project/messer && pnpm install --no-frozen-lockfile",
  "buildCommand": "ROOT=$(pwd) && MESSER_DIR=$ROOT/messer-project/messer && cd $MESSER_DIR && pnpm --filter @workspace/db run push || true && pnpm --filter @workspace/gsm-africa run build && cd $ROOT && MESSER_DIR=$MESSER_DIR node $MESSER_DIR/scripts/build-vercel-handler.mjs",
  "framework": null,
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}