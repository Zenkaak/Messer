{
  "installCommand": "pnpm install --no-frozen-lockfile && cd gsm-world && pnpm install --no-frozen-lockfile",
  "buildCommand": "bash gsm-world/scripts/vercel-build.sh",
  "framework": null,
  "crons": [
    {
      "path": "/api/admin/cron/refresh-models",
      "schedule": "0 4 */2 * *"
    },
    {
      "path": "/api/admin/cron/abandoned-carts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin/cron/daily-marketing",
      "schedule": "50 0 * * *"
    }
  ]
}
