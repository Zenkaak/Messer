{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "bash scripts/vercel-build.sh",
  "framework": null,
  "env": {
    "PORT": "24115",
    "BASE_PATH": "/"
  },
  "crons": [
    {
      "path": "/api/admin/cron/refresh-models",
      "schedule": "0 4 */2 * *"
    },
    {
      "path": "/api/admin/cron/abandoned-carts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin/cron/daily-marketing",
      "schedule": "50 0 * * *"
    }
  ]
}
